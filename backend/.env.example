# Server
PORT=3001
NODE_ENV=development

# MySQL
# DB_NAME is overridden for isolated runs:
#   - tests use mini_mall_test (vitest.config.ts)
#   - E2E uses mini_mall_e2e (backend/package.json e2e:* scripts)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mini_mall
DB_USER=root
DB_PASSWORD=

# CORS
CORS_ORIGIN=http://localhost:5173

# JWT — rotate in prod; startup throws if unset in production
JWT_SECRET=dev-insecure-secret-change-me

# 待支付订单超过此分钟数后自动取消（库存原路返还）。留空走默认 30 分钟。
ORDER_EXPIRY_MINUTES=30
